---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import GalleryCard from '../components/GalleryCard.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

const galleries = (await getCollection('galleries')).sort(
  (a, b) => a.data.order - b.data.order
);
---

<Layout title="Home">
  <Header />
  <main class="flex-1">
    <Hero />
    <section class="px-6 pb-16">
      <div class="max-w-7xl mx-auto grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {galleries.map((gallery) => (
          <GalleryCard
            title={gallery.data.title}
            slug={gallery.id}
            cover={gallery.data.cover}
            year={gallery.data.year}
          />
        ))}
      </div>
    </section>
  </main>
  <Footer />
</Layout>
