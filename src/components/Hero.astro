---
import settings from '../data/settings.json';
---

<section class="pt-32 pb-16 px-6">
  <div class="max-w-3xl mx-auto text-center">
    <p class="text-base md:text-lg text-white/70 leading-relaxed max-w-2xl mx-auto">
      {settings.tagline}
    </p>
    <a
      href="/contact"
      class="inline-block mt-8 px-8 py-3 border border-white/20 text-sm tracking-wider text-white hover:bg-white hover:text-black transition-all duration-300"
    >
      {settings.bookingLabel}
    </a>
  </div>
</section>
