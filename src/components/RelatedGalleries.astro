---
interface Props {
  galleries: {
    title: string;
    slug: string;
    cover: string;
  }[];
}

const { galleries } = Astro.props;
---

{galleries.length > 0 && (
  <section class="mt-20 px-6">
    <div class="max-w-7xl mx-auto">
      <h3 class="text-lg font-medium mb-8 text-white/80">You may also like</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {galleries.map((gallery) => (
          <a href={`/gallery/${gallery.slug}`} class="group block relative overflow-hidden">
            <div class="aspect-[16/9] overflow-hidden">
              <img
                src={gallery.cover}
                alt={gallery.title}
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                loading="lazy"
              />
            </div>
            <div class="absolute inset-0 bg-black/20 group-hover:bg-black/40 transition-all duration-500 flex items-end">
              <div class="p-4">
                <h4 class="text-sm font-medium text-white tracking-wide">{gallery.title}</h4>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
)}
