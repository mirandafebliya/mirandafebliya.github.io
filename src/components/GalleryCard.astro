---
interface Props {
  title: string;
  slug: string;
  cover: string;
  year?: string;
}

const { title, slug, cover, year } = Astro.props;
---

<a href={`/gallery/${slug}`} class="group block relative overflow-hidden">
  <div class="aspect-[4/5] md:aspect-[3/4] overflow-hidden">
    <img
      src={cover}
      alt={title}
      class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
      loading="lazy"
    />
  </div>
  <div class="absolute inset-0 bg-black/0 group-hover:bg-black/30 transition-all duration-500 flex items-end">
    <div class="p-5 translate-y-2 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-500">
      {year && <span class="text-xs text-white/60 block mb-1">{year}</span>}
      <h3 class="text-sm md:text-base font-medium text-white tracking-wide">{title}</h3>
    </div>
  </div>
</a>
